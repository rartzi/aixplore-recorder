{
  "name": "aixplore-recorder",
  "version": "3.0.0",
  "description": "AIXplore Screen + Camera Recorder",
  "author": "AIXplore Ronen Artzi",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:unsigned": "electron-builder --mac --config.mac.identity=null --config.afterSign=''"
  },
  "devDependencies": { "electron": "^35.0.0", "electron-builder": "^26.0.0" },
  "dependencies": { "@ffmpeg-installer/ffmpeg": "^1.1.0" },
  "overrides": {
    "@electron/asar": "^4.0.1",
    "global-agent": "^4.1.2",
    "glob": "^13.0.6",
    "rimraf": "^6.1.3"
  },
  "build": {
    "appId": "com.aixplore.recorder",
    "productName": "AIXplore Recorder",
    "afterSign": "build/notarize.cjs",
    "extraResources": [
      { "from": "src/click-capture", "to": "click-capture" }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "identity": "AMANUEL RONEN ARTZI (Y7HVZ99HD3)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "x64ArchFiles": "**/node_modules/@ffmpeg-installer/**",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Camera access for webcam overlay",
        "NSMicrophoneUsageDescription": "Microphone access for audio recording",
        "NSScreenCaptureUsageDescription": "Screen capture for recording"
      }
    },
    "dmg": {
      "title": "AIXplore Recorder",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
